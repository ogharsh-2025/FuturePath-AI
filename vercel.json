{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://futurepath-backend-rn47.onrender.com/api/:path*"
    },
    {
      "source": "/assets/:path*",
      "destination": "/frontend/assets/:path*"
    },
    {
      "source": "/((?!api|assets|frontend).*)",
      "destination": "/frontend/index.html"
    }
  ]
}
